# Redis Configuration
# Copy this file to .env and fill in your actual values
# .env is in .gitignore and will not be committed

# Redis Cloud Connection (for production RAG index)
REDIS_URL=redis://default:YOUR_PASSWORD_HERE@YOUR_HOST:YOUR_PORT

# Example:
# REDIS_URL=redis://default:4nFe28n9bAUw5mhjivldh3bF9atjsUUO@redis-17562.crce219.us-east-1-4.ec2.cloud.redislabs.com:17562

# Local Redis (for development/testing)
# REDIS_URL=redis://localhost:6379

